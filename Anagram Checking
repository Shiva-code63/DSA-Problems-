// Anagram Checking 
class Solution {
public:
    bool isAnagram(string s, string t) {
        if (s.size() != t.size()) return false;
        vector<int> count(26,0);
        for (auto it : s) count[it - 'a']++;
        for (auto it : t) count[it - 'a']--;
        for (int it: count){
            if (it != 0) return false;
        }
        return true;
    }
};
