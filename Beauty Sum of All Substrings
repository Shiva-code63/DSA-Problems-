// Beauty Sum of All Substrings

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    int beautySum(string s) {
        int n = s.size();
        if (n == 1) return 0;
        int sum = 0;
        for (int i=0; i<n; i++){
            vector<int>freq(26, 0);
            for (int j=i; j<n; j++){
                freq[s[j] - 'a']++;     
                int min_occ = INT_MAX; 
                int max_occ = INT_MIN;
                for (int k=0; k<26; k++){
                    if (freq[k] > 0){
                        min_occ = min(min_occ, freq[k]);
                        max_occ = max(max_occ, freq[k]);
                    }
                }
                sum += (max_occ - min_occ);  
            }
        }
        return sum; 
    }
};
