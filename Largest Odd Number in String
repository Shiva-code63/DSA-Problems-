// Largest Odd Number in String
class Solution {
  public:
    string maxOdd(string s) {
        int n = s.size();
        for (int i = s.size() - 1; i >= 0; i--) {
            if ((s[i] - '0') % 2 == 1) {
                return s.substr(0, i + 1);
            }
        }
        return "";
    }
};
